servicename = "connection-manager"

# Default config for connection manager
listen_port = 8091

# Keyvault credentials.
keyvault_id = "@CONNECTIONMANAGER_ID@"
keyvault_secret = "@CONNECTIONMANAGER_SECRET@"

[tls]
# Microservice https server settings
enable_https_server = true
certificate = "/opt/privx/cert/connection-manager.crt"
private_key = "/opt/privx/cert/connection-manager.key"

[ueba]
# UEBA server and trainer image versions
version_dev = "1.2"
version_live = "1.2"

